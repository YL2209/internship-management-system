# ============================================================
# 实习数据管理系统 — 环境变量 (.env)
# ============================================================
# 使用: cp .env.example .env && vi .env
# 注意: .env 含敏感信息，已被 .dockerignore 排除，勿提交 Git
# ============================================================

# --- Web 管理后台 ---

# 宿主机映射端口 (默认 5000)
WEB_PORT=5000

# 管理员密码 — 必须设置！选择一个强密码
# ADMIN_PASSWORD 或 ADMIN_PASSWORD_HASH 二选一
ADMIN_PASSWORD=
# 或直接提供 bcrypt 哈希 (优先级更高)
# ADMIN_PASSWORD_HASH=

# JWT 签名密钥 — 生产环境务必设置 64+ 字符随机串
# 留空则每次重启后所有已签发 token 失效
JWT_SECRET=

# Token 过期时间 (小时, 默认 8)
JWT_EXPIRATION_HOURS=8

# 登录速率限制 (每分钟最大尝试次数, 默认 10)
LOGIN_RATE_LIMIT=10

# 触发限制后锁定时长 (秒, 默认 300)
LOGIN_LOCKOUT_SECONDS=300

# --- 签到守护进程 ---

# 日志级别: DEBUG | INFO | WARNING | ERROR (默认 INFO)
LOG_LEVEL=INFO

# --- 时区 ---
TZ=Asia/Shanghai
